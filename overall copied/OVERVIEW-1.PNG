<!DOCTYPE html>
<!-- saved from url=(0162)file:///C:/Users/dayab/UofT/WINTER%202026/MIE1624H%20Intro%20to%20Data/course%20project/EXECUTION/project/outputs/dashboard/overview_dashboard_interactive_v2.html -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  
  <title>Overview Copy v2</title>
  <script src="./OVERVIEW-1_files/plotly-2.32.0.min.js.download"></script><style id="plotly.js-style-global"></style>
  <style>
    :root {
      --ink: #0f172a;
      --bg: #f8fafc;
      --panel: #ffffff;
      --muted: #64748b;
    }
    * { box-sizing: border-box; }
    body { margin:0; padding:24px; font-family: Segoe UI, Inter, system-ui, sans-serif; color:var(--ink); background:var(--bg); }
    h1 { margin:0 0 6px; }
    .row { display:grid; grid-template-columns:48px 1fr; gap:10px; margin-bottom:14px; }
    .vert-label { writing-mode:vertical-rl; transform:rotate(180deg); text-align:center; font-weight:700; letter-spacing:1px; color:#f8fafc; font-size:12px; display:flex; align-items:center; justify-content:center; background:#1f2937; border-radius:12px; padding:8px 6px; }
    .grid-cols { display:grid; grid-template-columns: repeat(auto-fit, minmax(280px,1fr)); gap:12px; }
    .card { background:var(--panel); border-radius:14px; padding:14px; border:1px solid #e2e8f0; }
    .pill { display:inline-flex; padding:6px 10px; border-radius:999px; font-size:12px; background:#fff; border:1px solid #e2e8f0; }
    .bar { position:relative; height:8px; background:rgba(15,23,42,0.08); border-radius:999px; overflow:hidden; margin:6px 0 2px; }
    .bar span { position:absolute; top:0; left:0; bottom:0; width:var(--w,0%); background:linear-gradient(90deg,#fbcfe8,#bfdbfe); }
    .actions { display:grid; gap:6px; margin-top:8px; }
    .action-tag { padding:6px 9px; border-radius:10px; background:#f1f5f9; font-size:13px; }
    .meta { display:flex; gap:8px; flex-wrap:wrap; margin-top:8px; }
    .badge { padding:4px 8px; border-radius:999px; font-size:12px; border:1px solid #e2e8f0; background:#fff; }
    .chart-grid { display:grid; grid-template-columns: repeat(auto-fit,minmax(320px,1fr)); gap:12px; }
    .top-chips { display:flex; gap:10px; flex-wrap:wrap; margin:8px 0 14px; }
    .chip { background:#fff; border:1px solid #e2e8f0; border-radius:999px; padding:6px 10px; font-size:12px; color:#334155; }
  </style>
<style id="plotly.js-style-modebar-01804a"></style><style id="plotly.js-style-modebar-d8a03a"></style></head>
<body>
  <h1>Overview</h1>
  <div class="top-chips" id="summaryChips"><span class="chip">Canada baseline rank: #5</span><span class="chip">Canada baseline composite: 32.86</span><span class="chip">2029Q4 all-recs median: 36.93 (rank #4)</span></div>
  <div class="row"><div class="vert-label">CHALLENGES</div><div class="grid-cols" id="problemCols"><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgb(238, 244, 255));"><div class="pill">20% attrition baseline</div><h3>Canada's AI Talent Paradox</h3><div style="color:#64748b;font-size:14px">High acquisition, weak retention; Canada trains and attracts talent but leaks senior value creation south.</div><div class="bar" style="--w:55%"><span></span></div><div style="color:#64748b;font-size:12px">Urgency index: 55% | Talent score anchor = 41.94</div></div><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgb(255, 244, 232));"><div class="pill">Commercial Ecosystem score = 10.27</div><h3>The Commercialization Valley of Death</h3><div style="color:#64748b;font-size:14px">Canada produces research and technical feasibility, but scale-up and domestic commercial capture remain weak.</div><div class="bar" style="--w:55%"><span></span></div><div style="color:#64748b;font-size:12px">Urgency index: 55% | Commercial Ecosystem score = 10.27</div></div><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgb(234, 248, 245));"><div class="pill">R3 conversion baseline proxy = 25%</div><h3>Weak Market Validation / First-Customer Gap</h3><div style="color:#64748b;font-size:14px">Risk-averse adoption and weak first-buyer pathways stop domestic firms from proving market value.</div><div class="bar" style="--w:55%"><span></span></div><div style="color:#64748b;font-size:12px">Urgency index: 55% | R3 conversion baseline proxy = 25%</div></div></div></div>
  <div class="row"><div class="vert-label">RECOMMENDATIONS &amp; ACTIONS</div><div class="grid-cols" id="recCols"><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgb(238, 244, 255));"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px"><input class="checkbox" type="checkbox" id="rec1" checked=""><span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:800;letter-spacing:.4px;background:#EEF4FF;color:#4F7CCB;border:1.5px solid #4F7CCB">R1</span></div><div style="font-size:14px;font-weight:700;color:#0f172a;line-height:1.3;margin-bottom:8px">Build Career Moats for Talent</div><div class="actions"><span class="action-tag">Elite equity tax exemption</span><span class="action-tag">1:1 salary-matching tax credit</span><span class="action-tag">AI Elite fast-track visa and PR mechanism</span></div><div class="meta"><span class="badge">1-3 years</span><span class="badge">Policy package</span></div><div style="color:#64748b;font-size:13px;margin-top:6px">Closes gaps on 6 KPIs</div></div><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgb(255, 244, 232));"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px"><input class="checkbox" type="checkbox" id="rec2" checked=""><span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:800;letter-spacing:.4px;background:#FFF4E8;color:#D4832E;border:1.5px solid #D4832E">R2</span></div><div style="font-size:14px;font-weight:700;color:#0f172a;line-height:1.3;margin-bottom:8px">Build the Conditions to Scale AI in Canada</div><div class="actions"><span class="action-tag">Compute utilization and access support</span><span class="action-tag">Procurement and pilot-to-contract conversion</span><span class="action-tag">Growth-stage co-investment and later-stage capital</span></div><div class="meta"><span class="badge">1-3 years</span><span class="badge">Policy package</span></div><div style="color:#64748b;font-size:13px;margin-top:6px">Closes gaps on 4 KPIs</div></div><div class="card" style="background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgb(234, 248, 245));"><div style="display:flex;align-items:center;gap:8px;margin-bottom:4px"><input class="checkbox" type="checkbox" id="rec3" checked=""><span style="display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:999px;font-size:12px;font-weight:800;letter-spacing:.4px;background:#EAF8F5;color:#2E9C8F;border:1.5px solid #2E9C8F">R3</span></div><div style="font-size:14px;font-weight:700;color:#0f172a;line-height:1.3;margin-bottom:8px">Stimulate B2B Demand via Adoption Credits</div><div class="actions"><span class="action-tag">Refundable first-customer AI adoption credit</span><span class="action-tag">Canadian-owned and Canadian-IP eligibility rules</span><span class="action-tag">Conversion mandate with clawback logic</span></div><div class="meta"><span class="badge">1-3 years</span><span class="badge">Policy package</span></div><div style="color:#64748b;font-size:13px;margin-top:6px">Closes gaps on 5 KPIs</div></div></div></div>
  <div class="row" style="margin-bottom:0;"><div class="vert-label">IMPACTS</div><div class="chart-grid"><div class="card"><h3>Success metrics</h3><div id="clustered" style="height:360px;" class="js-plotly-plot"><div class="plot-container plotly"><div class="user-select-none svg-container" style="position: relative; width: 100%; height: 100%;"><svg class="main-svg" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="991.512" height="360" style="background: rgb(255, 255, 255);"><defs id="defs-01804a"><g class="clips"><clippath id="clip01804axyplot" class="plotclip"><rect width="902" height="163"></rect></clippath><clippath class="axesclip" id="clip01804ax"><rect x="70" y="0" width="902" height="360"></rect></clippath><clippath class="axesclip" id="clip01804ay"><rect x="0" y="76" width="991.512" height="163"></rect></clippath><clippath class="axesclip" id="clip01804axy"><rect x="70" y="76" width="902" height="163"></rect></clippath></g><g class="gradients"></g><g class="patterns"></g></defs><g class="bglayer"><rect class="bg" x="70" y="76" width="902" height="163" style="fill: rgb(248, 250, 252); fill-opacity: 1; stroke-width: 0;"></rect></g><g class="draglayer cursor-crosshair"><g class="xy"><rect class="nsewdrag drag" data-subplot="xy" x="70" y="76" width="902" height="163" style="fill: transparent; stroke-width: 0; pointer-events: all;"></rect><rect class="nwdrag drag cursor-nw-resize" data-subplot="xy" x="50" y="56" width="20" height="20" style="fill: transparent; stroke-width: 0; pointer-events: all;"></rect><rect class="nedrag drag cursor-ne-resize" data-subplot="xy" x="972" y="56" width="20" height="20" style="fill: transparent; stroke-width: 0; pointer-events: all;"></rect><rect class="swdrag drag cursor-sw-resize" data-subplot="xy" x="50" y="239" width="20" height="20" style="fill: transparent; stroke-width: 0; pointer-events: all;"></rect><rect class="sedrag drag cursor-se-resize" data-subplot="xy" x="972" y="239" width="20" 